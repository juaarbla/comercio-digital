# Agregador de Noticias FP Comercio
# Copia este archivo como .env y rellena los valores

# ── LLM ───────────────────────────────────────────────
# Opciones: "ollama" | "anthropic"
LLM_PROVIDER=ollama

# Ollama (activo por defecto)
OLLAMA_BASE_URL=
CHAT_MODEL=gemma4:latest

# Anthropic (descomenta si cambias LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-aqui-tu-clave

# Configuración del agregador
HORAS_RECIENTES=48

# ── Imágenes ──────────────────────────────────────────
# Opciones: "rss" | "openai"
IMAGE_PROVIDER=rss

# OpenAI DALL-E (solo si IMAGE_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_IMG_MODEL=dall-e-3
# OPENAI_IMG_SIZE=1792x1024

# ── Newsletter por Mailgun ────────────────────────────
# El envio real requiere ejecutar enviar_newsletter_mailgun.py con --send --yes.
MAIL_PROVIDER=mailgun
MAILGUN_REGION=eu
MAILGUN_API_BASE=https://api.eu.mailgun.net
MAILGUN_DOMAIN=mg.comerciodigital.net
MAILGUN_API_KEY=
MAILGUN_FROM="ComercioDigital.net <newsletter@mg.comerciodigital.net>"
MAILGUN_REPLY_TO="ComercioDigital.net <tu-correo@example.com>"
NEWSLETTER_BASE_URL=https://comerciodigital.net/newsletter/
NEWSLETTER_UNSUBSCRIBE_TEXT="Para dejar de recibir esta newsletter, responde a este correo con BAJA."

# SMTP queda documentado por si se usa en otro proyecto. Este agregador envia por API.
MAILGUN_SMTP_HOST=smtp.eu.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_USER=
MAILGUN_SMTP_PASSWORD=

MAIL_DRY_RUN=true
