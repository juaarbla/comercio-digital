# Agregador de Noticias FP Comercio
# Copia este archivo como .env y rellena los valores

# ── LLM ───────────────────────────────────────────────
# Opciones: "ollama" | "anthropic"
LLM_PROVIDER=ollama

# Ollama (activo por defecto)
OLLAMA_BASE_URL=
CHAT_MODEL=gemma4:latest

# Anthropic (descomenta si cambias LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-aqui-tu-clave

# Configuración del agregador
HORAS_RECIENTES=48

# ── Imágenes ──────────────────────────────────────────
# Opciones: "rss" | "openai"
IMAGE_PROVIDER=rss

# OpenAI DALL-E (solo si IMAGE_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_IMG_MODEL=dall-e-3
# OPENAI_IMG_SIZE=1792x1024